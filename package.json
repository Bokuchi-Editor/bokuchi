{
  "name": "bokuchi",
  "private": true,
  "version": "0.7.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "npm run check && tauri dev",
    "tauri:dev:clean": "rm -f \"$HOME/Library/Application Support/com.pemomomo.bokuchi/.app-state.dat\" && npm run tauri:dev",
    "tauri:dev:dynamic": "node scripts/tauri-dev.js",
    "tauri:build": "tauri build",
    "dev:standalone": "npm run build && npm run tauri:dev",
    "get-port": "node scripts/get-port.js",
    "dev:dynamic": "PORT=$(npm run get-port --silent) vite",
    "check": "npm run lint && npm run type-check",
    "lint": "eslint . --max-warnings 0",
    "type-check": "tsc --noEmit",
    "test": "cd src-tauri && cargo test",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:rust": "cd src-tauri && cargo test",
    "test:rust:verbose": "cd src-tauri && cargo test --verbose",
    "test:all": "npm run test:rust && npm run test:unit",
    "audit": "npm audit",
    "audit:fix": "npm audit fix",
    "security:check": "npm audit && npm run security:check:cargo",
    "security:check:cargo": "cd src-tauri && cargo audit",
    "verify-release": "./scripts/verify-release-build.sh",
    "build:windows": "./build-windows.sh",
    "build:macos": "./build-macos.sh",
    "build:macos:signed": "./build-macos-signed.sh",
    "notarize": "./notarize.sh",
    "generate-latest-json": "node scripts/generate-latest-json.js"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@monaco-editor/react": "^4.7.0",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.5.0",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-store": "^2.4.2",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "@tauri-apps/plugin-window-state": "^2.4.0",
    "highlight.js": "^11.11.1",
    "i18next": "^25.10.10",
    "katex": "^0.16.44",
    "marked": "^16.4.2",
    "mermaid": "^11.13.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-i18next": "^15.7.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/katex": "^0.16.8",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/coverage-v8": "^4.1.2",
    "audit-ci": "^7.0.1",
    "eslint": "^10.1.0",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-checker": "^0.12.0",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "dompurify": ">=3.2.4",
    "flatted": ">=3.4.0",
    "minimatch": ">=10.2.1"
  }
}
